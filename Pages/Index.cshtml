                    <input type="text">

                    <p>Type</p>
                    <select name="type">
                        <option value="1">Single</option>
                        <option value="2">EP</option>
                        <option value="3">LP</option>
                    </select>

                    <p>Description</p>
                    <input class="Description" type="text">

                </div>
                <div class="col-lg-4">
                    <p>Tracks</p>
                <div>
                    <ul >
                      <li>
