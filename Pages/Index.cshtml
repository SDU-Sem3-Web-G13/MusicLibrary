                      </li>
                      <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    <li>
                        <input type="text">
                    </li>
                    </ul>
                </div>
                </div>
                <div class="button">
                    <button class="button">Add album</button>

                </div>
        </form>
</body>
</html>