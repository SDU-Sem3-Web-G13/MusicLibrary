@page
@using RazorMusic.Models
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <!-- Link CSS here (only for this page) -->
    <link href="~/css/formPage.css" rel="stylesheet" />
</head>
<body>
    

<form action="">
            <div class="row">
                <p>Submission form</p>
                <div class="col-lg-4">
                    <p>Album Name</p>
                    <input type="text">

                    <p>Release Date</p>
                    <input type="date">

                </div>
                <div class="col-lg-4">
